{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://the-guy.dev/schema/pack.json",
  "title": "The Guy pack manifest",
  "type": "object",
  "required": [
    "version",
    "id",
    "displayName",
    "packageName",
    "packVersion",
    "minimumRuntimeVersion",
    "maximumTestedRuntimeVersion",
    "assets"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "0.1"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "displayName": {
      "type": "string",
      "minLength": 1
    },
    "packageName": {
      "type": "string",
      "minLength": 1
    },
    "packVersion": {
      "type": "string",
      "minLength": 1
    },
    "minimumRuntimeVersion": {
      "type": "string",
      "minLength": 1
    },
    "maximumTestedRuntimeVersion": {
      "type": "string",
      "minLength": 1
    },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "source", "destination", "strategy", "required"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "source": {
            "type": "string",
            "pattern": "^\\./"
          },
          "destination": {
            "type": "string",
            "minLength": 1
          },
          "strategy": {
            "type": "string",
            "enum": ["copy"]
          },
          "required": {
            "type": "boolean"
          },
          "templateContext": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "default": []
          }
        },
        "additionalProperties": false
      }
    },
    "postInstall": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object",
        "required": ["id", "cwd", "run"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "cwd": {
            "type": "string",
            "minLength": 1
          },
          "run": {
            "type": "string",
            "minLength": 1
          },
          "optional": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
